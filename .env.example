# SGRC Backend — variables de entorno (plantilla — copiar a .env y editar)

# MySQL 8 (local o gestionado). En producción añade el pool: ?connection_limit=20&pool_timeout=20
DATABASE_URL="mysql://root:REEMPLAZAR_PASSWORD@localhost:3306/sgrc"

# JWT
JWT_SECRET="cambiar-este-secret-en-produccion-min-32-caracteres-aleatorios"
JWT_EXPIRES_IN="8h"
REFRESH_SECRET="otro-secret-distinto-para-refresh-tokens"
REFRESH_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV=development

# CORS
FRONTEND_ORIGIN="http://localhost:5173,http://localhost:5174"

# Notificaciones (vacío en dev → se omiten)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="SGRC <noreply@cofca.co>"

WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
WHATSAPP_FROM=""

# Rate limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_GLOBAL=100
